generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. З таблиці room_type ми ВИДАЛИЛИ поле description
model room_type {
  type_id    Int       @id @default(autoincrement())
  type_name  String    @db.VarChar(50)
  base_price Decimal   @db.Decimal(8, 2)
  room       room[]
}

// 2. У таблицю guest ми ДОДАЛИ поле is_vip
model guest {
  guest_id         Int       @id @default(autoincrement())
  name             String    @db.VarChar(50)
  surname          String    @db.VarChar(50)
  passport_details String    @unique @db.VarChar(50)
  phone            String?   @db.VarChar(20)
  email            String?   @unique @db.VarChar(100)
  is_vip           Boolean   @default(false) // Ось це нове поле
  booking          booking[]
  review           review[]  // Зв'язок з новою таблицею відгуків
}

model room {
  room_id     Int       @id @default(autoincrement())
  room_number String    @unique @db.VarChar(10)
  status      String?   @default("вільний") @db.VarChar(20)
  type_id     Int?
  room_type   room_type? @relation(fields: [type_id], references: [type_id], onDelete: Restrict)
  booking     booking[]
  review      review[]   // Зв'язок з новою таблицею відгуків
}

model booking {
  booking_id     Int       @id @default(autoincrement())
  check_in_date  DateTime  @db.Date
  check_out_date DateTime  @db.Date
  booking_status String?   @default("підтверджено") @db.VarChar(20)
  guest_id       Int?
  room_id        Int?
  guest          guest?    @relation(fields: [guest_id], references: [guest_id], onDelete: Cascade)
  room           room?     @relation(fields: [room_id], references: [room_id], onDelete: Restrict)
  payment        payment[]
}

model payment {
  payment_id   Int       @id @default(autoincrement())
  amount       Decimal   @db.Decimal(8, 2)
  payment_date DateTime? @default(now()) @db.Timestamp(6)
  booking_id   Int?
  booking      booking?  @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
}

// 3. Це абсолютно НОВА ТАБЛИЦЯ для відгуків
model review {
  review_id Int     @id @default(autoincrement())
  rating    Int
  comment   String?
  guest_id  Int
  room_id   Int
  guest     guest   @relation(fields: [guest_id], references: [guest_id], onDelete: Cascade)
  room      room    @relation(fields: [room_id], references: [room_id], onDelete: Cascade)
}